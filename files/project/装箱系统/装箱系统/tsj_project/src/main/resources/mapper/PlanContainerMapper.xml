<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tsj.mapper.PlanContainerMapper">

    <resultMap id="PlanContainerResultMap" type="com.tsj.entity.PlanContainer">
        <id property="id" column="id"/>
        <result property="planId" column="plan_id"/>
        <result property="containerId" column="container_id"/>
        <result property="containerQty" column="container_qty"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, plan_id, container_id, container_qty
    </sql>

    <insert id="insert" parameterType="com.tsj.entity.PlanContainer" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO plan_container (plan_id, container_id, container_qty)
        VALUES (#{planId}, #{containerId}, #{containerQty})
    </insert>

    <update id="update" parameterType="com.tsj.entity.PlanContainer">
        UPDATE plan_container
        SET plan_id = #{planId},
            container_id = #{containerId},
            container_qty = #{containerQty}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM plan_container WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="PlanContainerResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM plan_container
        WHERE id = #{id}
    </select>

    <select id="selectByPlanId" resultMap="PlanContainerResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM plan_container
        WHERE plan_id = #{planId}
        ORDER BY id
    </select>

    <select id="countByContainerId" resultType="int">
        SELECT COUNT(*) FROM plan_container WHERE container_id = #{containerId}
    </select>

</mapper>

