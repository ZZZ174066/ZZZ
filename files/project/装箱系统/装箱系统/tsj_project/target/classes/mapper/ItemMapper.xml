<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tsj.mapper.ItemMapper">

    <resultMap id="ItemResultMap" type="com.tsj.entity.Item">
        <id property="itemId" column="item_id"/>
        <result property="itemName" column="item_name"/>
        <result property="lengthMm" column="length_mm"/>
        <result property="widthMm" column="width_mm"/>
        <result property="heightMm" column="height_mm"/>
        <result property="quantity" column="quantity"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        item_id, item_name, length_mm, width_mm, height_mm, quantity, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.tsj.entity.Item" useGeneratedKeys="true" keyProperty="itemId">
        INSERT INTO item (item_name, length_mm, width_mm, height_mm, quantity)
        VALUES (#{itemName}, #{lengthMm}, #{widthMm}, #{heightMm}, #{quantity})
    </insert>

    <update id="update" parameterType="com.tsj.entity.Item">
        UPDATE item
        SET item_name = #{itemName},
            length_mm = #{lengthMm},
            width_mm = #{widthMm},
            height_mm = #{heightMm},
            quantity = #{quantity}
        WHERE item_id = #{itemId}
    </update>

    <delete id="deleteById">
        DELETE FROM item WHERE item_id = #{id}
    </delete>

    <select id="selectById" resultMap="ItemResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM item
        WHERE item_id = #{id}
    </select>

    <select id="selectAll" resultMap="ItemResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM item
        ORDER BY item_id DESC
    </select>

</mapper>

