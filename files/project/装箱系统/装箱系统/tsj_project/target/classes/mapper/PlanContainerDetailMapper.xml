<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tsj.mapper.PlanContainerDetailMapper">

    <resultMap id="PlanContainerDetailResultMap" type="com.tsj.entity.PlanContainerDetail">
        <id property="id" column="id"/>
        <result property="planId" column="plan_id"/>
        <result property="containerId" column="container_id"/>
        <result property="filled" column="filled"/>
        <result property="filledItemQty" column="filled_item_qty"/>
        <result property="fillRate" column="fill_rate"/>
        <result property="avgSupportRate" column="avg_support_rate"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, plan_id, container_id, filled, filled_item_qty, fill_rate, avg_support_rate
    </sql>

    <insert id="insert" parameterType="com.tsj.entity.PlanContainerDetail" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO plan_container_detail (plan_id, container_id, filled, filled_item_qty, fill_rate, avg_support_rate)
        VALUES (#{planId}, #{containerId}, #{filled}, #{filledItemQty}, #{fillRate}, #{avgSupportRate})
    </insert>

    <update id="update" parameterType="com.tsj.entity.PlanContainerDetail">
        UPDATE plan_container_detail
        SET plan_id = #{planId},
            container_id = #{containerId},
            filled = #{filled},
            filled_item_qty = #{filledItemQty},
            fill_rate = #{fillRate},
            avg_support_rate = #{avgSupportRate}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM plan_container_detail WHERE id = #{id}
    </delete>

    <delete id="deleteByPlanId">
        DELETE FROM plan_container_detail WHERE plan_id = #{planId}
    </delete>

    <select id="selectById" resultMap="PlanContainerDetailResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM plan_container_detail
        WHERE id = #{id}
    </select>

    <select id="selectByPlanId" resultMap="PlanContainerDetailResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM plan_container_detail
        WHERE plan_id = #{planId}
        ORDER BY id
    </select>

</mapper>

